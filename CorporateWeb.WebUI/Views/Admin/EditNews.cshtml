@model CorporateWeb.Entities.News
@{
    ViewData["Title"] = "Edit Feed Content";
}

<div class="container my-5 pt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Breadcrumb Navigation -->
            <div class="mb-4">
                <a asp-controller="Admin" asp-action="Index" class="text-decoration-none small font-monospace text-muted hover-link">&larr; Back to Control Panel</a>
            </div>

            <!-- Form Card Blueprint -->
            <div class="card shadow-sm border border-light-subtle rounded-4 overflow-hidden">
                <div class="card-header bg-dark text-white p-3">
                    <h5 class="m-0 fw-bold font-monospace small text-uppercase tracking-wider">Modify Project Feed Node (ID: @Model.Id)</h5>
                </div>
                <div class="card-body p-4 bg-white">
                    <form asp-controller="Admin" asp-action="EditNews" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <!-- Title Input Section -->
                        <div class="mb-4">
                            <label asp-for="Title" class="form-label font-monospace small fw-bold text-uppercase tracking-wide text-secondary">Update / Project Title</label>
                            <input asp-for="Title" class="form-control rounded-3 py-2 px-3 fw-bold text-dark border-light-subtle custom-input" placeholder="Enter update title..." required />
                        </div>

                        <!-- Description Textarea Section -->
                        <div class="mb-4">
                            <label asp-for="Description" class="form-label font-monospace small fw-bold text-uppercase tracking-wide text-secondary">Card Snippet / Insight Description</label>
                            <textarea asp-for="Description" class="form-control rounded-3 py-2 px-3 border-light-subtle custom-input" rows="6" placeholder="Enter insight text..." required></textarea>
                        </div>

                        <!-- Control Action Buttons -->
                        <div class="d-flex align-items-center justify-content-end gap-2 pt-2 border-top">
                            <a asp-controller="Admin" asp-action="Index" class="btn btn-light px-4 rounded-pill fw-bold font-monospace style-btn-text">Cancel</a>
                            <button type="submit" class="btn btn-info text-white px-4 rounded-pill fw-bold font-monospace style-btn-text btn-save">Save System Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .tracking-wider { letter-spacing: 0.06em; }
    .tracking-wide { letter-spacing: 0.03em; }
    .style-btn-text { font-size: 0.8rem; }
    .custom-input:focus {
        border-color: #0dcaf0 !important;
        box-shadow: 0 0 0 0.25rem rgba(13, 202, 240, 0.12) !important;
    }
    .btn-save { transition: all 0.25s ease; }
    .btn-save:hover { box-shadow: 0 4px 12px rgba(13, 202, 240, 0.2); }
</style>