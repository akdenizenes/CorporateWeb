@{ ViewData["Title"] = "Create New Insight"; }

<div class="container my-5 pt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="mb-4"><a href="/Admin" class="text-decoration-none small font-monospace text-muted">&larr; Back to Control Panel</a></div>
            <div class="card shadow-sm border border-light-subtle rounded-4 overflow-hidden">
                <div class="card-header bg-dark text-white p-3">
                    <h5 class="m-0 fw-bold font-monospace small text-uppercase tracking-wider">Deploy New Insight Node</h5>
                </div>
                <div class="card-body p-4 bg-white">
                    <form method="post" action="/Admin/CreateNews">
                        @Html.AntiForgeryToken()
                        
                        <div class="mb-4">
                            <label class="form-label font-monospace small fw-bold text-uppercase text-secondary">Title</label>
                            <input type="text" name="title" class="form-control rounded-3 py-2 px-3 fw-bold text-dark border-light-subtle" required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label font-monospace small fw-bold text-uppercase text-secondary">Description</label>
                            <textarea name="description" class="form-control rounded-3 py-2 px-3 border-light-subtle" rows="6" required></textarea>
                        </div>

                        <div class="mb-4">
                            <label class="form-label font-monospace small fw-bold text-uppercase text-secondary">Image URL</label>
                            <input type="text" name="imageUrl" class="form-control rounded-3 py-2 px-3 border-light-subtle" placeholder="https://..." />
                            <small class="text-muted font-monospace small">Optional: Leave empty for default visual.</small>
                        </div>

                        <div class="mb-4">
                            <label class="form-label font-monospace small fw-bold text-uppercase text-secondary">Insight Date</label>
                            <input type="date" name="createdDate" class="form-control rounded-3 py-2 px-3 border-light-subtle" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                        </div>

                        <div class="d-flex justify-content-end gap-2 pt-2 border-top">
                            <a href="/Admin" class="btn btn-light px-4 rounded-pill fw-bold font-monospace" style="font-size:0.8rem;">Cancel</a>
                            <button type="submit" class="btn btn-info text-white px-4 rounded-pill fw-bold font-monospace" style="font-size:0.8rem;">Publish Insight</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>