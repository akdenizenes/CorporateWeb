@model IEnumerable<CorporateWeb.Entities.News>
@{
    ViewData["Title"] = "Haberler & Projeler";
}

<div class="container my-5 py-4">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-dark">Haberler & Projeler</h1>
        <p class="lead text-muted">Ekibimizden en son güncellemeler ve yeni geliştirdiğimiz projeler.</p>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6">
                <div class="card shadow-sm border-0 h-100 flex-column flex-lg-row overflow-hidden rounded-3">
                    <img src="@item.ImageUrl" class="img-fluid" alt="@item.Title"
                         style="width: 100%; max-width: 300px; object-fit: cover;">
                    <div class="card-body p-4 d-flex flex-column justify-content-center">
                        <span class="badge bg-dark mb-2 align-self-start">@item.CreatedDate.ToString("dd.MM.yyyy")</span>
                        <h5 class="card-title fw-bold">@item.Title</h5>
                        <p class="card-text text-secondary mt-2 mb-0">@item.Description</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>