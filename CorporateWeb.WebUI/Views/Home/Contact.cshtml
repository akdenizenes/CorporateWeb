@{
    ViewData["Title"] = "Contact";
}

<div class="container my-5 py-4">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold">Get In Touch</h1>
        <p class="lead text-muted">
            Feel free to reach out for projects, internship/career opportunities, or just to chat about technology.
        </p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-5 mb-4">
            <div class="card h-100 border-0 shadow-sm bg-dark text-white p-4">
                <h4 class="fw-bold mb-4">Contact Information</h4>
                <ul class="list-unstyled fs-5">
                    <li class="mb-4">
                        <strong>📍 Location:</strong><br>
                        Ereğli, Zonguldak, Turkey <br>
                        <span class="text-muted fs-6">(Education & Internship Period: Muğla)</span>
                    </li>
                    <li class="mb-4">
                        <strong>📧 Email:</strong><br>
                        <a href="mailto:enesakdeniz306@gmail.com"
                           class="text-info text-decoration-none">enesakdeniz306@gmail.com</a>
                    </li>
                    <li class="mb-4">
                        <strong>💼 LinkedIn:</strong><br>
                        <a href="https://www.linkedin.com/in/enes-akdeniz-a5267a386/" target="_blank"
                           class="text-info text-decoration-none">linkedin.com/in/enes-akdeniz-a5267a386</a>
                    </li>
                    <li class="mb-3">
                        <strong>🐙 GitHub:</strong><br>
                        <a href="https://github.com/akdenizenes" target="_blank"
                           class="text-info text-decoration-none">github.com/akdenizenes</a>
                    </li>
                </ul>
            </div>
        </div>

        <div class="col-md-7">
            <div class="card border-0 shadow-sm p-4 h-100">
                <form method="post" asp-action="Contact" asp-controller="Home">
                    @if (ViewBag.Message != null)
                    {
                        <div class="alert alert-@ViewBag.AlertType shadow-sm mb-4">
                            @ViewBag.Message
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Full Name</label>
                        <input type="text" class="form-control" name="name" placeholder="John Doe" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email Address</label>
                        <input type="email" class="form-control" name="email" placeholder="example@mail.com" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Your Message</label>
                        <textarea class="form-control" name="message" rows="4" placeholder="Type your message here..."
                                  required></textarea>
                    </div>
                    <button type="submit" class="btn btn-dark w-100 fw-bold">Send Message</button>
                </form>
            </div>
        </div>
    </div>
</div>