@model IEnumerable<CorporateWeb.Entities.Service>
@{
    ViewData["Title"] = "Hizmetlerimiz";
}

<div class="container my-5 py-4">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-dark">Hizmetlerimiz</h1>
        <p class="lead text-muted">Modern teknolojilerle geliştirdiğimiz profesyonel çözümlerimiz.</p>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow border-0 rounded-3">
                    <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title"
                         style="height: 220px; object-fit: cover;">
                    <div class="card-body p-4">
                        <h4 class="card-title fw-bold">@item.Title</h4>
                        <p class="card-text text-secondary mt-3">@item.Description</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>