@model IEnumerable<CorporateWeb.Entities.Service>
@{
    ViewData["Title"] = "Our Services";
}

<div class="container my-5 py-4">
    <div class="text-center mb-5 animate-fade-in">
        <span class="badge bg-info bg-opacity-10 text-info fw-bold px-3 py-2 rounded-pill mb-2 text-uppercase tracking-wider">Expertise</span>
        <h1 class="display-5 fw-bold text-dark tracking-tight">Core Services</h1>
        <p class="lead text-muted px-4 max-w-xl mx-auto">
            Professional enterprise-level software solutions architected and developed with cutting-edge tech stacks.
        </p>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border border-light-subtle rounded-4 overflow-hidden custom-service-card">
                    <div class="service-img-wrapper overflow-hidden" style="height: 220px;">
                        <img src="@item.ImageUrl" class="w-100 h-100 service-card-img" alt="@item.Title" style="object-fit: cover;">
                    </div>
                    <div class="card-body p-4 bg-white">
                        <h4 class="card-title fw-bold text-dark tracking-tight mb-3">@item.Title</h4>
                        <p class="card-text text-secondary small lh-relaxed">@item.Description</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .tracking-tight {
        letter-spacing: -0.02em;
    }
    .tracking-wider {
        letter-spacing: 0.08em;
    }
    .max-w-xl {
        max-width: 36rem;
    }

    /* Premium Card Engineering */
    .custom-service-card {
        transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.4s ease, border-color 0.4s ease;
    }
    .custom-service-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06) !important;
        border-color: rgba(13, 202, 240, 0.2) !important;
    }

    /* Soft Zoom for Inner Images */
    .service-card-img {
        transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
    }
    .custom-service-card:hover .service-card-img {
        transform: scale(1.04);
    }
</style>