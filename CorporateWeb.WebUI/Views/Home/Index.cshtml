@model CorporateWeb.WebUI.Models.HomeViewModel
@{
    ViewData["Title"] = "Anasayfa";
}

<div class="bg-dark text-white text-center py-5 mb-5 rounded">
    @if (Model.AboutPage != null)
    {
        <h1 class="display-4 fw-bold">@Model.AboutPage.Title</h1>
        <p class="lead text-light px-5 opacity-75">@Model.AboutPage.Description</p>
    }
    else
    {
        <h1 class="display-4 fw-bold">Kurumsal Dünyamıza Hoş Geldiniz</h1>
        <p class="lead text-muted">Geleceğin teknolojilerini profesyonel çözümlerle buluşturuyoruz.</p>
    }
</div>

<div class="container">
    <h2 class="border-bottom pb-3 mb-4 text-dark fw-bold">Hizmetlerimiz</h2>
    <div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
        @foreach (var service in Model.Services)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <img src="@service.ImageUrl" class="card-img-top" alt="@service.Title"
                         style="height: 200px; object-fit: cover;">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">@service.Title</h5>
                        <p class="card-text text-secondary">@service.Description</p>
                    </div>
                </div>
            </div>
        }
    </div>

    <h2 class="border-bottom pb-3 mb-4 text-dark fw-bold">Ekibimizden Güncel Haberler</h2>
    <div class="row row-cols-1 row-cols-md-2 g-4 mb-5">
        @foreach (var news in Model.News)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 flex-md-row">
                    <img src="@news.ImageUrl" class="card-img-left rounded-start" alt="@news.Title"
                         style="width: 200px; object-fit: cover;">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">@news.Title</h5>
                        <p class="card-text text-secondary" style="font-size: 0.9rem;">@news.Description</p>
                        <span class="badge bg-secondary">@news.CreatedDate.ToString("dd.MM.yyyy")</span>
                    </div>
                </div>
            </div>
        }
    </div>
</div>