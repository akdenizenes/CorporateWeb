@model CorporateWeb.WebUI.Models.HomeViewModel
@{
    ViewData["Title"] = "Home";
}

<div class="jumbotron position-relative text-white rounded-4 overflow-hidden mb-5 shadow" 
     style="background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); padding: 5rem 2rem;">
    <div class="position-absolute top-0 start-0 w-100 h-100 bg-grid-pattern opacity-10"></div>
    <div class="container position-relative text-center">
        @if (Model.AboutPage != null)
        {
            <h1 class="display-4 fw-extrabold tracking-tight mb-3">@Model.AboutPage.Title</h1>
            <p class="lead text-light-50 px-md-5 mx-auto max-w-3xl opacity-80 fs-5">@Model.AboutPage.Description</p>
        }
        else
        {
            <h1 class="display-4 fw-extrabold tracking-tight mb-3">Welcome to My Corporate Showcase</h1>
            <p class="lead text-muted px-md-5 mx-auto max-w-3xl fs-5 text-white-50">
                Architecting innovative cloud ecosystems and cross-platform solutions integrated with cutting-edge software standards.
            </p>
        }
        <div class="mt-4">
            <a asp-controller="Home" asp-action="Contact" class="btn btn-info btn-lg px-4 fw-bold text-uppercase tracking-wider rounded-pill shadow-sm custom-hero-btn">Get In Touch</a>
        </div>
    </div>
</div>

<div class="container">
    <div class="d-flex align-items-center mb-4 border-bottom pb-3">
        <h2 class="text-dark fw-bold tracking-tight m-0">Core Expertise & Services</h2>
    </div>
    <div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
        @foreach (var service in Model.Services)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border border-light-subtle rounded-4 overflow-hidden custom-premium-card">
                    <div class="card-img-wrapper overflow-hidden" style="height: 200px;">
                        <img src="@service.ImageUrl" class="card-img-top w-100 h-100" alt="@service.Title" style="object-fit: cover;">
                    </div>
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold text-dark tracking-tight mb-2">@service.Title</h5>
                        <p class="card-text text-secondary small lh-relaxed">@service.Description</p>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="d-flex align-items-center mb-4 border-bottom pb-3">
        <h2 class="text-dark fw-bold tracking-tight m-0">Latest Updates & Insights</h2>
    </div>
    <div class="row row-cols-1 row-cols-xl-2 g-4 mb-5">
        @foreach (var news in Model.News)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border border-light-subtle rounded-4 overflow-hidden flex-column flex-md-row custom-premium-card">
                    <div class="card-img-wrapper overflow-hidden" style="min-width: 200px; max-width: 100%; height: 200px;">
                        <img src="@news.ImageUrl" class="w-100 h-100" alt="@news.Title" style="object-fit: cover;">
                    </div>
                    <div class="card-body p-4 d-flex flex-column justify-content-between">
                        <div>
                            <div class="mb-2">
                                <span class="badge bg-secondary bg-opacity-10 text-secondary fw-semibold font-monospace px-2 py-1" style="font-size: 0.75rem;">
                                    📅 @news.CreatedDate.ToString("MMM dd, yyyy")
                                </span>
                            </div>
                            <h5 class="card-title fw-bold text-dark tracking-tight mb-2">@news.Title</h5>
                            <p class="card-text text-secondary small lh-base">@news.Description</p>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .fw-extrabold { font-weight: 800; }
    .tracking-tight { letter-spacing: -0.02em; }
    .tracking-wider { letter-spacing: 0.05em; }
    .max-w-3xl { max-width: 48rem; }

    /* Custom Hero Button Glow */
    .custom-hero-btn {
        transition: all 0.3s ease;
    }
    .custom-hero-btn:hover {
        background: #0dbaf0 !important;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(13, 202, 240, 0.3) !important;
    }

    /* Premium Component Interactive Animations */
    .custom-premium-card {
        transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.4s ease, border-color 0.4s ease;
        background: #ffffff;
    }
    .custom-premium-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06) !important;
        border-color: rgba(13, 202, 240, 0.2) !important;
    }

    /* Soft Zoom for Inner Images */
    .card-img-wrapper img {
        transition: transform 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
    }
    .custom-premium-card:hover .card-img-wrapper img {
        transform: scale(1.04);
    }
</style>